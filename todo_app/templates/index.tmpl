<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{{.Title}} · Todo</title>
    <link rel="stylesheet" href="/statics/style.css" />
  </head>
  <body>
    <main class="card">
      <header>
        <p class="eyebrow">TODAY</p>
        <h1>{{.Title}}</h1>
        <p class="subtitle">Small steps still count.</p>
        <img class="image" src="/image" alt="Random image" />
      </header>

      <form class="add-form" method="post" action="/task">
        <label class="sr-only" for="new-todo">New todo</label>
        <div class="input-wrap">
          <input
            id="new-todo"
            name="title"
            placeholder="What needs to be done?"
            maxlength="140"
            required
          />
          <small id="new-todo-counter">0 / 140</small>
        </div>
        <button type="submit">Add</button>
      </form>

      <script>
        const input = document.getElementById("new-todo");
        const counter = document.getElementById("new-todo-counter");
        const max = input.maxLength;

        function updateCounter() {
          counter.textContent = `${input.value.length} / ${max}`;
        }

        updateCounter();

        input.addEventListener("input", updateCounter);
      </script>

      <ul class="todo-list">
        {{range .Todos}}
        <li>
          <label>
            <input type="checkbox" {{if .Completed}}checked{{end}} />
            <span>{{.Title}}</span>
          </label>
        </li>
        {{else}}
        <li class="empty">Nothing here—enjoy the quiet.</li>
        {{end}}
      </ul>

      <footer>{{len .Todos}} tasks</footer>
    </main>
  </body>
</html>
